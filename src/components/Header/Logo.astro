<a id="logo" href={`/`} data-fathom="logo" transition:persist="logo" aria-label="Home">
  <svg
    viewBox="0 0 48 64"
    width="48"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path
      class="mark mark-left"
      d="M14 12 L14 52"
      stroke="currentColor"
      stroke-width="4"
      pathLength="1"></path>
    <path
      class="mark mark-right"
      d="M34 12 L34 52"
      stroke="currentColor"
      stroke-width="4"
      pathLength="1"></path>
  </svg>

  <span class="visuallyhidden">Nikita</span>
</a>

<style lang="scss">
  #logo {
    width: 32px;
    height: 32px;
    transform: translateY(-0.05em) rotate(-8deg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  @keyframes stroke {
    from { stroke-dashoffset: 1; }
    to { stroke-dashoffset: 0; }
  }

  @media (prefers-reduced-motion: no-preference) {
    [data-animating="true"] {
      .mark {
        stroke-dasharray: 1;
        stroke-dashoffset: 1;
        animation-name: stroke;
        animation-timing-function: linear;
        animation-fill-mode: both;
      }

      .mark-left {
        animation-duration: 0.2s;
        animation-delay: 0s;
        animation-timing-function: cubic-bezier(0.75, 0, 0.2, 1);
      }

      .mark-right {
        animation-duration: 0.2s;
        animation-delay: 0.16s;
        animation-timing-function: cubic-bezier(0.8, 0, 0.2, 1);
      }
    }
  }

  .visuallyhidden {
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    height: 1px;
    overflow: hidden;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }
</style>

<script>
  function handleAnimation() {
    const logoElem = document.getElementById("logo");
    logoElem?.addEventListener("click", () => {
      if (logoElem.dataset.animating === "true") return;
      logoElem.dataset.animating = "true";

      setTimeout(() => {
        logoElem.dataset.animating = "false";
      }, 700);
    });
  }

  handleAnimation();
  document.addEventListener("astro:after-swap", () => handleAnimation());
</script>

<script>
  import * as Fathom from "fathom-client";

  document.addEventListener("astro:page-load", () => {
    document
      .querySelector("[data-fathom='logo']")
      ?.addEventListener("click", () => {
        Fathom.trackEvent("nav: click logo");
      });
  });
</script>
